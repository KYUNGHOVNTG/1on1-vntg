# ====================
# Application Settings
# ====================
APP_NAME=vibe-web-starter
APP_VERSION=0.1.0
DEBUG=True
ENVIRONMENT=development

# ====================
# API Settings
# ====================
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# ====================
# Database Settings (Supabase)
# ====================
# Supabase 대시보드 > Project Settings > Database > Connection string 참조
# Method: "Transaction pooler" 선택 권장 (포트 6543, asyncpg 최적화)

# ✅ 권장: DATABASE_URL 직접 설정
# 1. Supabase에서 Type=URI, Method="Transaction pooler" 선택
# 2. Connection string 복사 (postgresql+asyncpg://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres)
# 3. postgresql:// → postgresql+asyncpg:// 변경
# 4. 비밀번호 특수문자 URL 인코딩 (! → %21, @ → %40, # → %23)
#
# 예시:
DATABASE_URL=postgresql+asyncpg://postgres.YOUR_PROJECT_ID:YOUR_PASSWORD@aws-1-ap-northeast-2.pooler.supabase.com:6543/postgres

# 대안: 개별 변수로 설정 (Transaction pooler)
# DATABASE_URL 사용 시 아래 변수들은 무시됨
#POSTGRES_HOST=aws-0-region.pooler.supabase.com
#POSTGRES_PORT=6543
#POSTGRES_USER=postgres.YOUR_PROJECT_ID
#POSTGRES_PASSWORD=YOUR_PASSWORD
#POSTGRES_DB=postgres

# ====================
# DB Engine Options
# ====================
DB_ECHO=False
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# ====================
# Security Settings
# ====================
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ====================
# Logging Settings
# ====================
LOG_LEVEL=INFO

# ====================
# Google Cloud Storage (GCS) Settings
# ====================
# GCS 버킷 이름 (예: your-company-1on1-audio)
GCS_BUCKET_NAME=your-bucket-name
# GCS 프로젝트 ID
GCS_PROJECT_ID=your-project-id
# 서비스 계정 JSON 파일 경로 (비어있으면 Application Default Credentials 사용)
# 로컬 개발: /path/to/service-account.json
# 운영환경: GKE Workload Identity 또는 환경변수로 주입
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCS 버킷 CORS 설정 (cors.json 파일 생성 후 아래 명령어 실행):
# gcloud storage buckets update gs://{GCS_BUCKET_NAME} --cors-file=cors.json
# cors.json 예시는 docs/COACHING_AI_SYSTEM_ROADMAP.md 참조

# ====================
# OpenAI Settings
# ====================
# Whisper STT + GPT-4o (화자 분리, 요약, Action Item 추출)
OPENAI_API_KEY=sk-your-openai-api-key-here

# ====================
# Domain Plugin Settings
# ====================
# 도메인별 설정을 추가할 수 있습니다
# ENABLE_SAMPLE_DOMAIN=True
